# ---- Admin ----
# Password for the /admin dashboard. REQUIRED in production.
ADMIN_PASSWORD=change-me-to-a-strong-password

# ---- Supabase (required on Vercel / serverless) ----
# From Supabase → Project Settings → API.
# Use the SERVICE ROLE key (server-side only — never expose it to the browser).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: table name (defaults to "sessions")
# SUPABASE_TABLE=sessions

# ---- Admin submission notifications (optional) ----
# Where to email the admin when a client submits a form.
ADMIN_EMAIL=admin@example.com
# Public base URL of the deployment, used in the notification link.
PUBLIC_URL=https://your-app.vercel.app

# ---- Email sending (optional; needed for admin "Send by email") ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM="Pru Forms <forms@example.com>"

# ---- Local only ----
# PORT=3000
# If SUPABASE_URL is not set, the app uses local file storage under data/.
